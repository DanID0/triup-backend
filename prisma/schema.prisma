generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum Language {
  LATVIAN
  ENGLISH
  RUSSIAN
}

enum AccessType {
  Public
  Privates
}

enum InvitedUserRights {
  Guest
  Member
  Admin
}

enum Priority {
  Low
  Medium
  High
}

enum BoardActivityType {
  COMMENT
  TASK_CREATED
  TASK_UPDATED
  TASK_MOVED
  TASK_DELETED
  COLUMN_CREATED
  COLUMN_UPDATED
  COLUMN_DELETED
  BOARD_UPDATED
}

model User{
id String @id @default(uuid())
username String @unique
password String
email String @unique
avatarUrl String?
role Role @default(USER)
interfaceLanguage Language  @default(LATVIAN)
Workspace Workspace[]
Tasks Task[]
Comments Comment[]
hashedRefreshToken String?
UserBoard UserBoard[]
UserWorkspace UserWorkspace[]
BoardActivity BoardActivity[]
}

model UserWorkspace {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

 @@unique([userId, workspaceId])
}

model Workspace {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  name String
  accessType AccessType @default(Public)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Boards Board[]
  UserWorkspace UserWorkspace[]
}

model Board {
id String @id @default(uuid())
workspaceId String
workspace Workspace @relation(fields: [workspaceId], references: [id])
name String
backgroundImageUrl String?
shareToken String? @unique
UserBoard UserBoard[]
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
columns Column[]
activities BoardActivity[]
}

model UserBoard {
  id String  @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  boardId String
  board  Board  @relation(fields: [boardId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt
  invitedUserRights InvitedUserRights @default(Guest)

  @@unique([userId, boardId])
}

model BoardActivity {
  id String @id @default(uuid())
  boardId String
  board Board @relation(fields: [boardId], references: [id])
  userId String
  user User @relation(fields: [userId], references: [id])
  type BoardActivityType
  message String
  meta Json?
  createdAt DateTime @default(now())

  @@index([boardId, createdAt])
  @@index([userId])
}

model Column {
  id  String @id @default(uuid())
  boardId String
  board Board @relation(fields: [boardId], references: [id])
  name String @default("New Column")
  position Int  @default(0)
  color String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks  Task[]
}

model Task {
  id String @id @default(uuid())
  columnId String
  column Column @relation(fields: [columnId], references: [id])
  name  String
  description String?
  priority  Priority  @default(Medium)
  dueDate DateTime?
  completed Boolean @default(false)
  labels String[] @default([])
  attachments String[] @default([])
  assigneeId String?
  assignee User?  @relation(fields: [assigneeId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments Comment[]
}

model Comment {
  id String @id @default(uuid())
  taskId String
  task  Task @relation(fields: [taskId], references: [id])
  userId String
  user User @relation(fields: [userId], references: [id])
  content String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}